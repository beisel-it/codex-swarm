<section id="why-codex-swarm" class="section section--why">
  <div class="container why-grid">
    <div class="section-heading section-heading--sticky" data-reveal>
      <p class="eyebrow">{{ landing.why.eyebrow }}</p>
      <h2>{{ landing.why.title }}</h2>
      <p>{{ landing.why.intro }}</p>
    </div>
    <div class="why-grid__content">
      <div class="reason-cards">
        {% for card in landing.why.cards %}
          <article class="panel-frame reason-card" data-reveal style="--reveal-order: {{ loop.index }};">
            <h3>{{ card.title }}</h3>
            <p>{{ card.body }}</p>
          </article>
        {% endfor %}
      </div>
      <aside class="panel-frame evidence-panel" data-reveal>
        <p class="eyebrow eyebrow--compact">Evidence Layer</p>
        <h3>{{ landing.why.evidencePanel.title }}</h3>
        <ul>
          {% for item in landing.why.evidencePanel.items %}
            <li>{{ item }}</li>
          {% endfor %}
        </ul>
      </aside>
    </div>
  </div>
</section>
