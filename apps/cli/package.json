{
  "name": "@beisel-it/codex-swarm",
  "version": "0.1.1",
  "description": "Built-JS command line interface for Codex Swarm",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "codex-swarm": "./dist/bin/codex-swarm.js"
  },
  "files": [
    "dist",
    "README.md",
    "templates"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/beisel-it/codex-swarm.git",
    "directory": "apps/cli"
  },
  "homepage": "https://github.com/beisel-it/codex-swarm/tree/main/apps/cli",
  "bugs": {
    "url": "https://github.com/beisel-it/codex-swarm/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "codex",
    "swarm",
    "cli",
    "agents"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
