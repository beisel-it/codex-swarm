CODEX_SWARM_HOST=127.0.0.1
CODEX_SWARM_API_PORT=4300
CODEX_SWARM_POSTGRES_PORT=55439
CODEX_SWARM_REDIS_PORT=56379

CODEX_SWARM_DB_PASSWORD=change-me

CODEX_SWARM_DATABASE_URL=postgres://postgres:change-me@127.0.0.1:55439/codex_swarm
CODEX_SWARM_REDIS_URL=redis://127.0.0.1:56379

CODEX_SWARM_ARTIFACT_STORAGE_ROOT=__HOME__/.local/share/codex-swarm/artifacts
CODEX_SWARM_WORKSPACE_ROOT=__HOME__/.local/share/codex-swarm/workspaces
CODEX_SWARM_ARTIFACT_BASE_URL=http://127.0.0.1:4300

CODEX_SWARM_API_BASE_URL=http://127.0.0.1:4300

# Release browser auth defaults. After install/start, create the first admin with:
# codex-swarm auth bootstrap-admin --email <email> --password <password> --display-name <name> --yes
AUTH_SESSION_COOKIE_NAME=codex_swarm_session
AUTH_SESSION_TTL_SECONDS=604800
AUTH_SESSION_COOKIE_SAME_SITE=lax
# Leave AUTH_SESSION_COOKIE_SECURE unset to follow NODE_ENV.
# Set to true if this host is always reached over HTTPS.
# AUTH_SESSION_COOKIE_SECURE=true

# Password hashing parameters for local email/password auth.
AUTH_PASSWORD_SCRYPT_N=16384
AUTH_PASSWORD_SCRYPT_R=8
AUTH_PASSWORD_SCRYPT_P=1
AUTH_PASSWORD_SCRYPT_KEYLEN=64

# Release-mode service credential for worker and local-daemon control-plane calls.
AUTH_SERVICE_TOKEN=change-me-service-token
CODEX_SWARM_SERVICE_TOKEN=change-me-service-token
CODEX_SWARM_SERVICE_NAME=local-daemon

# Legacy bearer-token fallback is disabled by default.
AUTH_ENABLE_LEGACY_DEV_BEARER=false
# DEV_AUTH_TOKEN=change-me-only-if-you-enable-the-legacy-dev-bearer-fallback

CODEX_SWARM_CODEX_COMMAND=codex
CODEX_SWARM_NODE_ID=00000000-0000-4000-8000-000000000001
CODEX_SWARM_NODE_NAME=local-worker-1
CODEX_SWARM_CAPABILITIES=local,workspace-write
CODEX_SWARM_WORKER_ENDPOINT=
CODEX_SWARM_HEARTBEAT_INTERVAL_SECONDS=30
CODEX_SWARM_WORKER_POLL_INTERVAL_MS=2000
CODEX_SWARM_RECONCILE_ON_START=true
