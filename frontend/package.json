{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:readme-capture": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "runtime-config:write": "node ../ops/deploy/write-frontend-runtime-config.mjs",
    "build": "tsc -b && vite build && node ../ops/deploy/write-frontend-runtime-config.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "test": "vitest run",
    "lint": "eslint .",
    "preview": "node ../ops/deploy/write-frontend-runtime-config.mjs && vite preview"
  },
  "dependencies": {
    "@codex-swarm/contracts": "workspace:*",
    "@fontsource/iosevka": "^5.2.5",
    "@fontsource/iosevka-aile": "^5.2.5",
    "@fontsource/iosevka-etoile": "^5.2.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.2"
  }
}
