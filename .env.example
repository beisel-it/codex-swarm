PORT=3000
HOST=0.0.0.0
DATABASE_URL=postgres://postgres:postgres@localhost:5432/codex_swarm
DEV_AUTH_TOKEN=codex-swarm-dev-token
DEV_AUTH_PRINCIPAL=dev-user
DEV_AUTH_ACTOR_ID=dev-user
DEV_AUTH_ROLE=platform-admin
DEV_AUTH_TEAM_ID=codex-swarm
DEV_AUTH_POLICY_PROFILE=standard
RETENTION_RUN_DAYS=30
RETENTION_ARTIFACT_DAYS=30
RETENTION_EVENT_DAYS=30
SECRET_SOURCE_MODE=environment
# Set SECRET_SOURCE_MODE=external_manager and SECRET_PROVIDER=vault for governed repos.
SECRET_PROVIDER=
REMOTE_SECRET_ENV_NAMES=OPENAI_API_KEY
SECRET_ALLOWED_TRUST_LEVELS=trusted
SENSITIVE_POLICY_PROFILES=sensitive,breakglass
SECRET_DISTRIBUTION_BOUNDARY=control-plane issues short-lived credentials,workers get task-scoped env,sensitive repositories require policy-driven secret access
POLICY_DRIVEN_SECRET_ACCESS=false
