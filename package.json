{
  "name": "codex-swarm-workspace",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/beisel-it/codex-swarm.git"
  },
  "bugs": {
    "url": "https://github.com/beisel-it/codex-swarm/issues"
  },
  "homepage": "https://github.com/beisel-it/codex-swarm",
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.28.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.29.7",
    "markdownlint-cli": "^0.48.0",
    "prettier": "^3.8.2",
    "vitest": "^4.1.4"
  },
  "scripts": {
    "ci:agent-docs": "node ./scripts/ci/validate-agent-docs.mjs",
    "lint:markdown": "markdownlint \"**/*.md\" --ignore node_modules --ignore frontend/node_modules --ignore dist --ignore frontend/dist --ignore .git",
    "lint:markdown:fix": "markdownlint \"**/*.md\" --fix --ignore node_modules --ignore frontend/node_modules --ignore dist --ignore frontend/dist --ignore .git",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:markdown": "prettier --write \"**/*.md\"",
    "format:markdown:check": "prettier --check \"**/*.md\"",
    "changeset": "changeset",
    "changeset:status": "changeset status --verbose",
    "release:version": "changeset version",
    "release:bundle": "node ./scripts/release/create-single-host-bundle.mjs",
    "release:verify-bundle": "node ./scripts/release/verify-single-host-bundle.mjs",
    "release:publish": "changeset publish",
    "release:ci": "corepack pnpm ci:build && corepack pnpm release:publish",
    "dev:api": "pnpm --dir apps/api dev",
    "dev:cli": "pnpm --dir apps/cli build && node ./apps/cli/dist/bin/codex-swarm.js --help",
    "dev:worker": "pnpm --dir apps/worker dev",
    "dev:frontend": "pnpm --dir frontend dev",
    "dev:frontend:readme-capture": "pnpm --dir frontend dev:readme-capture",
    "tui": "node ./scripts/tui/start.mjs",
    "tui:capture": "node ./scripts/tui/capture.mjs",
    "ci:lint": "corepack pnpm lint:markdown && node ./scripts/ci/run-stage.mjs lint",
    "ci:typecheck": "node ./scripts/ci/run-stage.mjs typecheck",
    "ci:test": "node ./scripts/ci/run-stage.mjs test",
    "ci:build": "node ./scripts/ci/run-stage.mjs build",
    "ops:backup": "node ./apps/api/scripts/ops/backup-control-plane.mjs",
    "ops:restore": "node ./apps/api/scripts/ops/restore-control-plane.mjs",
    "ops:drill": "node ./apps/api/scripts/ops/dr-exercise.mjs",
    "ops:install:single-host": "bash ./ops/deploy/install-single-host.sh",
    "ops:m9:prepare": "node ./apps/api/scripts/ops/prepare-m9-workdir.mjs",
    "ops:perf": "node ./apps/api/scripts/ops/perf-envelope.mjs",
    "ops:smoke": "node ./apps/api/scripts/ops/single-host-smoke.mjs",
    "ops:tailnet:status": "bash ./ops/deploy/check-tailnet-instance.sh",
    "ops:tailnet:tui": "bash ./ops/deploy/run-tailnet-tui.sh",
    "ops:tailnet:workers:bootstrap": "bash ./ops/deploy/bootstrap-tailnet-workers.sh",
    "ops:tailnet:multi-agent-proof": "bash ./ops/deploy/run-tailnet-multi-agent-proof.sh"
  }
}
