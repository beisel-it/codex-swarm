[Unit]
Description=Codex Swarm Postgres (tailnet-only deployment)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=%h/.config/codex-swarm/tailnet.env
Restart=always
RestartSec=5
ExecStartPre=-/usr/bin/docker rm -f codex-swarm-postgres
ExecStart=/bin/sh -lc '/usr/bin/docker run --rm --name codex-swarm-postgres \
  -e POSTGRES_USER=postgres \
  -e POSTGRES_PASSWORD="$CODEX_SWARM_DB_PASSWORD" \
  -e POSTGRES_DB=codex_swarm \
  -v "$HOME/.local/share/codex-swarm/postgres:/var/lib/postgresql/data" \
  -p 127.0.0.1:${CODEX_SWARM_POSTGRES_PORT}:5432 \
  postgres:16'
ExecStop=/usr/bin/docker stop codex-swarm-postgres

[Install]
WantedBy=default.target
