[Unit]
Description=Codex Swarm Redis (tailnet-only deployment)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=%h/.config/codex-swarm/tailnet.env
Restart=always
RestartSec=5
ExecStartPre=-/usr/bin/docker rm -f codex-swarm-redis
ExecStart=/bin/sh -lc '/usr/bin/docker run --rm --name codex-swarm-redis \
  -v "$HOME/.local/share/codex-swarm/redis:/data" \
  -p 127.0.0.1:${CODEX_SWARM_REDIS_PORT}:6379 \
  redis:7-alpine --appendonly yes'
ExecStop=/usr/bin/docker stop codex-swarm-redis

[Install]
WantedBy=default.target
